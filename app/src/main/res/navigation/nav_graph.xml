<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/userReposFragment">

    <fragment
        android:id="@+id/userReposFragment"
        android:name="com.example.github_api_app.view.UserReposFragment"
        android:label="UserRepos"
        tools:layout="@layout/user_repos_fragment" >
        <action
            android:id="@+id/action_userReposFragment_to_repoDetailsFragment"
            app:destination="@id/repoDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/repoDetailsFragment"
        android:name="com.example.github_api_app.view.RepoDetailsFragment"
        android:label="RepoDetails"
        tools:layout="@layout/repo_details_fragment" >
        <argument
            android:name="repoName"
            app:argType="string"/>
    </fragment>

</navigation>