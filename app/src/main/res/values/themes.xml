<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Github_api_app" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorOnSurface">@color/primary_text</item>
    </style>

    <style name="Theme.Github_api_app" parent="Base.Theme.Github_api_app" />

    <style name="TextStyle" parent="Widget.AppCompat.TextView">
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextStyle.Secondary" parent="TextStyle">
        <item name="android:textColor">@color/secondary_text</item>
    </style>
</resources>