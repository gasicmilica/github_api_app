<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:fillViewport="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/header_view"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:background="@color/tertiary_background"
            app:layout_constraintBottom_toTopOf="@id/tv_tags"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_owner_avatar"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/icon_user" />

        <TextView
            android:id="@+id/tv_owner_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:textStyle="bold"
            style="@style/TextStyle"
            android:textSize="16sp"
            app:layout_constraintVertical_bias="0"
            app:layout_constraintBottom_toBottomOf="@+id/header_view"
            app:layout_constraintEnd_toEndOf="@+id/iv_owner_avatar"
            app:layout_constraintStart_toStartOf="@+id/iv_owner_avatar"
            app:layout_constraintTop_toBottomOf="@+id/iv_owner_avatar"
            tools:text="The Octocat" />

        <TextView
            android:id="@+id/tv_repo_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="24dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            style="@style/TextStyle"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/tv_watchers"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iv_owner_avatar"
            app:layout_constraintTop_toTopOf="@+id/iv_owner_avatar"
            tools:text="hello-world" />

        <TextView
            android:id="@+id/tv_watchers"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:text="@string/watchers"
            style="@style/TextStyle"
            app:layout_constraintBottom_toTopOf="@+id/tv_forks"
            app:layout_constraintEnd_toStartOf="@+id/tv_forks"
            app:layout_constraintStart_toEndOf="@+id/iv_owner_avatar"
            app:layout_constraintTop_toBottomOf="@id/tv_repo_name" />

        <TextView
            android:id="@+id/tv_watchers_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/rounded_background"
            android:gravity="center"
            android:padding="8dp"
            style="@style/TextStyle"
            app:layout_constraintVertical_bias="0"
            app:layout_constraintBottom_toBottomOf="@+id/header_view"
            app:layout_constraintEnd_toEndOf="@+id/tv_watchers"
            app:layout_constraintStart_toStartOf="@+id/tv_watchers"
            app:layout_constraintTop_toBottomOf="@+id/tv_watchers"
            tools:text="12" />

        <TextView
            android:id="@+id/tv_forks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/forks"
            style="@style/TextStyle"
            app:layout_constraintEnd_toEndOf="@id/tv_repo_name"
            app:layout_constraintStart_toEndOf="@+id/tv_watchers"
            app:layout_constraintTop_toTopOf="@id/tv_watchers" />

        <TextView
            android:id="@+id/tv_forks_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/rounded_background"
            android:gravity="center"
            android:padding="8dp"
            style="@style/TextStyle"
            app:layout_constraintBottom_toBottomOf="@+id/tv_watchers_count"
            app:layout_constraintEnd_toEndOf="@+id/tv_forks"
            app:layout_constraintStart_toStartOf="@+id/tv_forks"
            app:layout_constraintTop_toBottomOf="@+id/tv_forks"
            tools:text="12" />

        <TextView
            android:id="@+id/tv_tags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="@string/tags"
            android:paddingTop="12dp"
            style="@style/TextStyle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_owner_name" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_tags"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_tags"
            tools:itemCount="14"
            tools:listitem="@layout/tag_item" />

        <include
            android:id="@+id/no_data_view"
            layout="@layout/no_data_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginVertical="24dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_tags" />


        <ProgressBar
            android:id="@+id/loader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>